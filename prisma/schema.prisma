generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Usuario {
  id           String   @id @default(cuid())
  email        String   @unique
  senhaHash    String
  nome         String
  nomeExibicao String?
  celular      String?
  numCurso     Int?     @unique // Nº Curso (ex: 751) — opcional
  role         String   @default("PARTICIPANTE") // ADMIN | GESTOR | PARTICIPANTE
  firstLogin   Boolean  @default(true)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())

  cumprimento     Cumprimento[]
  demandasResp    Demanda[]     @relation("DemandaResponsavel")
}

model Demanda {
  id            String   @id @default(cuid())
  titulo        String
  linkForm      String
  prazo         DateTime
  horaLimite    String
  responsavelId String
  ativa         Boolean  @default(true)
  criadaEm      DateTime @default(now())

  responsavel Usuario       @relation("DemandaResponsavel", fields: [responsavelId], references: [id])
  cumprimento Cumprimento[]
}

model Cumprimento {
  id           String   @id @default(cuid())
  usuarioId    String
  demandaId    String
  dataRegistro DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])
  demanda Demanda @relation(fields: [demandaId], references: [id])

  @@unique([usuarioId, demandaId])
}
